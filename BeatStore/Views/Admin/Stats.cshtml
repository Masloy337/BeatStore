@model BeatStore.Models.AdminStatsViewModel

@{
    ViewData["Title"] = "Дэшборд";
}

<style>
    /* 🔥 КАРТОЧКИ СТАТИСТИКИ */
    .stat-card {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 25px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        transition: transform 0.3s ease, border-color 0.3s ease;
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: #333;
        }

    .stat-icon {
        font-size: 30px;
        margin-bottom: 10px;
        opacity: 0.8;
    }

    .stat-value {
        font-size: 36px;
        font-weight: 800;
        color: #fff;
        line-height: 1.2;
    }

    .stat-title {
        color: #888;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    /* Фоновое свечение для карточки дохода */
    .glow-bg {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, rgba(29, 185, 84, 0.15) 0%, rgba(0,0,0,0) 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    /* 🔥 ПРЕМИАЛЬНАЯ ТАБЛИЦА */
    .table-container {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 20px;
        margin-top: 30px;
    }

    .custom-table {
        width: 100%;
        color: #fff;
        border-collapse: collapse;
    }

        .custom-table th {
            color: #888;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 12px;
            padding: 15px;
            border-bottom: 1px solid #333;
            text-align: left;
        }

        .custom-table td {
            padding: 15px;
            border-bottom: 1px solid #1a1a1a;
            vertical-align: middle;
            font-size: 15px;
        }

        .custom-table tbody tr {
            transition: background 0.2s ease;
        }

            .custom-table tbody tr:hover {
                background: rgba(255, 255, 255, 0.02);
            }
</style>

<div class="container mt-4">
    <h2 class="fw-bold mb-4" style="color: #fff;">📊 Дэшборд</h2>

    <div class="row g-4 mb-5">

        <div class="col-md-4">
            <div class="stat-card" style="border-color: rgba(29, 185, 84, 0.3);">
                <div class="glow-bg"></div>
                <div class="stat-icon">💰</div>
                <div class="stat-title">Общий доход</div>
                <div class="stat-value" style="color: #1db954;">$@Model.TotalRevenue</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon">📦</div>
                <div class="stat-title">Всего продаж</div>
                <div class="stat-value">@Model.TotalSales</div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon">🔥</div>
                <div class="stat-title">Самый продаваемый бит</div>
                <div class="stat-value" style="font-size: 24px; margin-top: auto;">@Model.TopBeatTitle</div>
                <div class="text-secondary small mt-1">@Model.TopBeatSales продаж</div>
            </div>
        </div>

    </div>

    <div class="table-container mb-5">
        <h4 class="fw-bold mb-4" style="color: #fff;">📈 Динамика продаж</h4>
        <div style="height: 300px; width: 100%;">
            <canvas id="salesChart"></canvas>
        </div>
    </div>

    <div class="table-container">
        <h4 class="fw-bold mb-4" style="color: #fff;">🏆 Статистика по битам</h4>

        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Название бита</th>
                        <th style="text-align: center;">Количество продаж</th>
                        <th style="text-align: right;">Суммарный доход</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var beat in Model.Beats)
                    {
                        <tr>
                            <td class="fw-bold">@beat.Title</td>
                            <td style="text-align: center;">
                                <span class="badge" style="background: #222; color: #fff; padding: 6px 12px; border-radius: 6px;">
                                    @beat.SalesCount
                                </span>
                            </td>
                            <td style="text-align: right; color: #1db954; font-weight: bold;">
                                $@beat.Revenue
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = [
        @foreach (var item in Model.SalesByDay)
        {
                @: "@item.Date.ToString("dd.MM")",
        }
    ];

    const data = [
        @foreach (var item in Model.SalesByDay)
        {
                @: @item.Count,
        }
    ];

    const ctx = document.getElementById('salesChart').getContext('2d');

    // Создаем неоновый градиент для графика
    let gradient = ctx.createLinearGradient(0, 0, 0, 300);
    gradient.addColorStop(0, 'rgba(29, 185, 84, 0.4)'); // Яркий зеленый сверху
    gradient.addColorStop(1, 'rgba(29, 185, 84, 0.0)'); // Прозрачный снизу

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Продажи',
                data: data,
                borderColor: '#1db954',       // Цвет линии
                backgroundColor: gradient,    // Заливка под линией
                borderWidth: 3,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#1db954',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6,
                fill: true,
                tension: 0.4                  // Плавные изгибы линии
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false // Скрываем легенду, она тут не нужна
                },
                tooltip: {
                    backgroundColor: '#111',
                    titleColor: '#888',
                    bodyColor: '#fff',
                    borderColor: '#333',
                    borderWidth: 1,
                    padding: 10,
                    displayColors: false
                }
            },
            scales: {
                x: {
                    grid: {
                        color: '#222',        // Темная сетка
                        drawBorder: false
                    },
                    ticks: {
                        color: '#888'         // Серый текст оси
                    }
                },
                y: {
                    grid: {
                        color: '#222',        // Темная сетка
                        drawBorder: false
                    },
                    ticks: {
                        color: '#888',        // Серый текст оси
                        stepSize: 1,          // Продажи идут поштучно
                        beginAtZero: true
                    }
                }
            }
        }
    });
</script>