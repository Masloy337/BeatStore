@model BeatStore.Models.AdminStatsViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Статистика продаж";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Карточки со статистикой */
    .stat-card {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(29, 185, 84, 0.1);
            border-color: #1db954;
        }

    .stat-title {
        color: #888;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .stat-value {
        color: #fff;
        font-size: 36px;
        font-weight: 800;
        margin: 0;
    }

        .stat-value.money {
            color: #1db954;
        }

        .stat-value.fire {
            color: #ff4757;
            font-size: 28px;
        }
    /* Чуть меньше для текста */

    /* Блок графика */
    .chart-container {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 25px;
        margin-top: 30px;
    }

    /* Таблица битов */
    .table-container {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 25px;
        margin-top: 30px;
        overflow-x: auto;
    }

    .table-dark {
        background-color: transparent;
        color: #fff;
    }

        .table-dark th {
            border-bottom: 2px solid #333;
            color: #888;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 13px;
            padding-bottom: 15px;
        }

        .table-dark td {
            border-bottom: 1px solid #222;
            vertical-align: middle;
            padding: 15px 10px;
        }

        .table-dark tbody tr:hover {
            background-color: rgba(255,255,255,0.02);
        }
</style>

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold m-0">📈 Дашборд продюсера</h2>
        <a href="/Admin/Create" class="btn fw-bold" style="background: #1db954; color: #000; border-radius: 8px;">+ Загрузить бит</a>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-title">Общая выручка</div>
                <div class="stat-value money">$@Model.TotalRevenue.ToString("0.00")</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-title">Продано битов</div>
                <div class="stat-value">@Model.TotalSales</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-title">Хит продаж</div>
                @if (!string.IsNullOrEmpty(Model.TopBeatTitle))
                {
                    <div class="stat-value fire">🔥 @Model.TopBeatTitle</div>
                    <div style="color: #888; font-size: 13px; margin-top: 5px;">Продаж: @Model.TopBeatSales</div>
                }
                else
                {
                    <div class="stat-value" style="color: #666; font-size: 20px;">Пока нет продаж</div>
                }
            </div>
        </div>
    </div>

    <div class="chart-container shadow-sm">
        <h4 class="text-white mb-4 fw-bold">Динамика продаж по дням</h4>
        <canvas id="salesChart" height="100"></canvas>
    </div>

    <div class="table-container shadow-sm">
        <h4 class="text-white mb-4 fw-bold">Детализация по трекам</h4>
        @if (Model.Beats != null && Model.Beats.Any())
        {
            <table class="table table-dark table-borderless mb-0">
                <thead>
                    <tr>
                        <th>Название бита</th>
                        <th class="text-center">Количество продаж</th>
                        <th class="text-end">Принес выручки</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var beat in Model.Beats.OrderByDescending(b => b.SalesCount))
                    {
                        <tr>
                            <td class="fw-bold" style="font-size: 15px;">@beat.Title</td>
                            <td class="text-center">
                                @if (beat.SalesCount > 0)
                                {
                                    <span class="badge" style="background: rgba(29, 185, 84, 0.2); color: #1db954; font-size: 14px;">@beat.SalesCount шт.</span>
                                }
                                else
                                {
                                    <span class="text-secondary">-</span>
                                }
                            </td>
                            <td class="text-end fw-bold" style="color: #1db954;">$@beat.Revenue.ToString("0.00")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-4 text-secondary">
                Нет данных для отображения.
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        // 1. Достаем данные из C# и превращаем их в JSON для JavaScript
        const chartLabels = @Html.Raw(Json.Serialize(Model.SalesByDay.Select(s => s.Date.ToString("dd.MM.yyyy"))));
        const chartData = @Html.Raw(Json.Serialize(Model.SalesByDay.Select(s => s.Count)));

        // 2. Ищем элемент <canvas>
        const ctx = document.getElementById('salesChart').getContext('2d');

        // 3. Создаем красивый градиент под линией графика
        let gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(29, 185, 84, 0.5)'); // Ярко-зеленый сверху
        gradient.addColorStop(1, 'rgba(29, 185, 84, 0.0)'); // Прозрачный снизу

        // 4. Инициализируем Chart.js
        new Chart(ctx, {
            type: 'line', // Тип графика - линия
            data: {
                labels: chartLabels, // Даты внизу
                datasets: [{
                    label: 'Количество продаж',
                    data: chartData, // Сами цифры
                    borderColor: '#1db954', // Цвет линии (Spotify Green)
                    backgroundColor: gradient, // Заливка под линией
                    borderWidth: 3,
                    pointBackgroundColor: '#141414',
                    pointBorderColor: '#1db954',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true, // Включаем заливку
                    tension: 0.4 // Делаем линию плавной (изгибающейся)
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }, // Прячем скучную легенду
                    tooltip: {
                        backgroundColor: 'rgba(20, 20, 20, 0.9)',
                        titleColor: '#888',
                        bodyColor: '#fff',
                        bodyFont: { weight: 'bold', size: 14 },
                        padding: 12,
                        borderColor: '#333',
                        borderWidth: 1,
                        displayColors: false
                    }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                        ticks: { color: '#888' }
                    },
                    y: {
                        beginAtZero: true, // Начинаем график с нуля
                        grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                        ticks: {
                            color: '#888',
                            stepSize: 1 // Шаг сетки (чтобы не было 1.5 продажи)
                        }
                    }
                }
            }
        });
    });
</script>