@{
    ViewData["Title"] = "Загрузка нового бита";
}

<style>
    .admin-container {
        max-width: 900px;
        margin: 0 auto;
        background: #141414;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid #222;
    }

    .form-control {
        background: #0a0a0a;
        border: 1px solid #333;
        color: #fff;
        padding: 10px 15px;
        border-radius: 8px;
    }

        .form-control:focus {
            background: #111;
            border-color: #1db954;
            color: #fff;
            box-shadow: 0 0 0 3px rgba(29, 185, 84, 0.2);
        }

    label {
        color: #aaa;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* 🔥 Стили для файловых инпутов */
    input[type=file]::file-selector-button {
        background: #222;
        border: none;
        color: #fff;
        padding: 8px 15px;
        border-radius: 6px;
        cursor: pointer;
        margin-right: 15px;
        transition: background 0.2s;
    }

        input[type=file]::file-selector-button:hover {
            background: #333;
        }

    input[type=file] {
        cursor: pointer;
    }

    /* 🔥 Стили для Прогресс-бара */
    .progress-container {
        display: none;
        margin-top: 25px;
    }

    .progress-bar-bg {
        width: 100%;
        height: 12px;
        background: #222;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: inset 0 1px 3px rgba(0,0,0,0.5);
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #1db954, #1ed760);
        width: 0%;
        transition: width 0.2s ease;
    }

    .progress-text {
        color: #fff;
        font-size: 14px;
        margin-top: 8px;
        text-align: center;
        font-weight: bold;
    }
</style>

<div class="admin-container shadow-lg">
    <h2 class="text-white mb-4 fw-bold">⚡ Загрузить бит</h2>

    <form id="uploadForm">

        <h5 class="text-white mb-3" style="border-bottom: 1px solid #333; padding-bottom: 10px;">Основная информация</h5>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Название бита</label>
                <input type="text" name="Title" class="form-control" required placeholder="Например: Dark Knight" />
            </div>
            <div class="col-md-6 mb-3">
                <label>Продюсер</label>
                <input type="text" name="ProducerName" class="form-control" value="@User.Identity.Name" required />
            </div>
            <div class="col-md-4 mb-3">
                <label>Жанр</label>
                <input type="text" name="Genre" class="form-control" required placeholder="Hip-Hop, Trap..." />
            </div>
            <div class="col-md-4 mb-3">
                <label>Темп (BPM)</label>
                <input type="number" name="Bpm" class="form-control" required placeholder="140" />
            </div>
            <div class="col-md-4 mb-3">
                <label>Теги (через запятую)</label>
                <input type="text" name="Tags" class="form-control" placeholder="dark, type beat, hard" />
            </div>
        </div>

        <h5 class="text-white mt-4 mb-3" style="border-bottom: 1px solid #333; padding-bottom: 10px;">Ценообразование ($)</h5>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label style="color: #1db954;">Витрина (Цена От)</label>
                <input type="number" name="Price" class="form-control" required placeholder="29" />
            </div>
            <div class="col-md-3 mb-3">
                <label>Basic (MP3)</label>
                <input type="number" name="BasicPrice" class="form-control" required placeholder="29" />
            </div>
            <div class="col-md-3 mb-3">
                <label>Premium (WAV)</label>
                <input type="number" name="PremiumPrice" class="form-control" required placeholder="79" />
            </div>
            <div class="col-md-3 mb-3">
                <label style="color: #ff4757;">Exclusive</label>
                <input type="number" name="ExclusivePrice" class="form-control" required placeholder="250" />
            </div>
        </div>

        <h5 class="text-white mt-4 mb-3" style="border-bottom: 1px solid #333; padding-bottom: 10px;">Файлы (Можно перетаскивать)</h5>
        <div class="row">
            <div class="col-md-6 mb-4">
                <label>🖼️ Обложка (JPG, PNG)</label>
                <input type="file" name="imageFile" class="form-control" accept="image/*" required />
            </div>
            <div class="col-md-6 mb-4">
                <label>📢 Демо с войстегами (MP3)</label>
                <input type="file" name="demoFile" class="form-control" accept=".mp3" required />
                <small class="text-secondary">Этот файл будет играть в плеере</small>
            </div>
            <div class="col-md-6 mb-4">
                <label>💿 Чистый MP3 (Для Basic)</label>
                <input type="file" name="mp3File" class="form-control" accept=".mp3" required />
            </div>
            <div class="col-md-6 mb-4">
                <label>🔥 WAV / ZIP Trackouts (Для Premium/Exclusive)</label>
                <input type="file" name="fullFile" class="form-control" accept=".wav,.zip" required />
            </div>
        </div>

        <button type="submit" id="submitBtn" class="btn w-100 fw-bold mt-2" style="background: #1db954; color: #000; padding: 14px; font-size: 16px; border-radius: 8px;">
            🚀 Начать загрузку
        </button>

        <div id="progressContainer" class="progress-container">
            <div class="progress-bar-bg">
                <div id="progressFill" class="progress-fill"></div>
            </div>
            <div id="progressText" class="progress-text">Подготовка...</div>
        </div>

    </form>
</div>

<script>
    document.getElementById('uploadForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const btn = document.getElementById('submitBtn');
        const progressContainer = document.getElementById('progressContainer');
        const progressFill = document.getElementById('progressFill');
        const progressText = document.getElementById('progressText');

        // Блокируем кнопку, чтобы не нажали дважды
        btn.disabled = true;
        btn.innerText = "Отправка данных...";
        progressContainer.style.display = "block";
        progressFill.style.width = '0%';
        progressFill.style.background = 'linear-gradient(90deg, #1db954, #1ed760)';

        // Собираем все текстовые поля и файлы автоматически!
        const formData = new FormData(this);

        const xhr = new XMLHttpRequest();

        // Отправляем на наш новый крутой метод в AdminController
        xhr.open('POST', '/Admin/CreateBeatAjax', true);

        // Магия отслеживания прогресса
        xhr.upload.onprogress = function(e) {
            if (e.lengthComputable) {
                const percentComplete = Math.round((e.loaded / e.total) * 100);
                progressFill.style.width = percentComplete + '%';
                progressText.innerText = `Загружено: ${percentComplete}%`;
            }
        };

        xhr.onload = function() {
            if (xhr.status === 200) {
                progressText.innerText = "Успешно! Бит добавлен в каталог ✅";
                setTimeout(() => window.location.href = '/Beats', 1500); // Редирект в каталог
            } else {
                let errorMsg = "Ошибка загрузки ❌";
                try {
                    let response = JSON.parse(xhr.responseText);
                    if(response.message) errorMsg = response.message;
                } catch(e) {}

                progressText.innerText = errorMsg;
                progressFill.style.background = "#ff4757";
                btn.disabled = false;
                btn.innerText = "Попробовать снова";
            }
        };

        xhr.onerror = function() {
            progressText.innerText = "Ошибка сети (проверьте подключение) ❌";
            progressFill.style.background = "#ff4757";
            btn.disabled = false;
            btn.innerText = "Попробовать снова";
        };

        xhr.send(formData);
    });
</script>