@model List<BeatStore.Models.Beat>

@{
    ViewData["Title"] = "Управление битами";
}

<style>
    /* Стили для строки бита в админке */
    .admin-row {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 15px;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .admin-row:hover {
            transform: translateX(5px);
            border-color: #333;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

    /* 🔥 Обложка с встроенным плеером (как в каталоге) */
    .image-wrapper {
        position: relative;
        overflow: hidden;
        border-radius: 10px;
        width: 70px;
        height: 70px;
        flex-shrink: 0;
    }

    .admin-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .admin-row:hover .admin-cover {
        transform: scale(1.05);
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .image-wrapper:hover .image-overlay {
        opacity: 1;
    }

    .overlay-play {
        background: #1db954;
        width: 35px;
        height: 35px;
        border-radius: 50%;
        border: none;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        color: #000;
        font-size: 14px;
        transition: transform 0.2s;
    }

        .overlay-play:hover {
            transform: scale(1.1);
            background: #1ed760;
        }

    .eq {
        display: flex;
        gap: 2px;
        align-items: flex-end;
        height: 12px;
    }

        .eq span {
            width: 2px;
            height: 4px;
            background: #000;
            animation: eqAnim 1s infinite ease-in-out;
        }
    @@keyframes eqAnim {
        0% {
            height: 4px;
        }

        50% {
            height: 12px;
        }

        100% {
            height: 4px;
        }
    }

    /* Бейджики для статистики */
    .stat-badge {
        background: #1a1a1a;
        border: 1px solid #333;
        padding: 6px 14px;
        border-radius: 10px;
        font-size: 13px;
        color: #aaa;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: color 0.2s, border-color 0.2s;
    }

        .stat-badge:hover {
            color: #1db954;
            border-color: #1db954;
        }

    /* Кнопка удаления с защитой */
    .delete-btn {
        background: rgba(255, 71, 87, 0.05);
        color: #ff4757;
        border: 1px solid rgba(255, 71, 87, 0.2);
        padding: 10px 20px;
        border-radius: 20px;
        font-weight: bold;
        font-size: 13px;
        transition: all 0.2s ease;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .delete-btn:hover {
            background: #ff4757;
            color: #fff;
            border-color: #ff4757;
            box-shadow: 0 4px 15px rgba(255, 71, 87, 0.4);
            transform: translateY(-2px);
        }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold m-0" style="color: #fff;">⚙️ Каталог битов</h2>
        <a href="/Admin/Create" class="btn fw-bold px-4 py-2 rounded-pill shadow" style="background: #1db954; color: #000; transition: transform 0.2s;">
            <span style="font-size: 16px; margin-right: 5px;">+</span> Добавить бит
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center p-5 shadow-lg" style="background: #141414; border-radius: 16px; border: 1px dashed #333;">
            <h1 style="font-size: 50px; margin-bottom: 15px;">🎛️</h1>
            <h4 class="text-white fw-bold">Ваш каталог пуст</h4>
            <p class="text-secondary mb-4">Загрузите свой первый бит, чтобы начать продажи.</p>
            <a href="/Admin/Create" class="btn btn-outline-light rounded-pill px-4">Загрузить трек</a>
        </div>
    }
    else
    {
        <div class="admin-list">
            @foreach (var beat in Model)
            {
                var producer = string.IsNullOrEmpty(beat.ProducerName) ? "unknown" : beat.ProducerName;
                var cover = beat.CoverImagePath ?? "/images/no-image.png";
                var fileName = System.IO.Path.GetFileName(beat.DemoAudioPath);
                var demoSrc = "/File/Demo?fileName=" + fileName;

                <div class="admin-row shadow-sm">

                    <div class="image-wrapper">
                        <img src="@cover" class="admin-cover" alt="@beat.Title" />
                        <div class="image-overlay">
                            <button class="overlay-play play-btn"
                                    data-id="@beat.Id"
                                    data-audio="@demoSrc"
                                    data-title="@beat.Title"
                                    data-cover="@cover"
                                    data-producer="@producer">
                                <span class="icon">▶</span>
                                <div class="eq" style="display:none;">
                                    <span></span><span></span><span></span>
                                </div>
                            </button>
                        </div>
                    </div>

                    <div class="flex-grow-1">
                        <h5 class="fw-bold text-white mb-1" style="font-size: 16px;">@beat.Title</h5>
                        <div class="text-secondary" style="font-size: 12px;">
                            prod. @producer • @beat.Bpm BPM • @beat.Genre
                        </div>
                    </div>

                    <div class="d-flex gap-2 d-none d-lg-flex">
                        <span class="stat-badge" title="Прослушивания">▶ @beat.PlayCount</span>
                        <span class="stat-badge" title="Лайки">❤️ @(beat.Likes?.Count ?? 0)</span>
                    </div>

                    <div class="ms-md-4 me-md-4 text-center" style="min-width: 90px;">
                        @if (beat.IsSold)
                        {
                            <span class="badge bg-dark text-secondary border border-secondary px-3 py-2">SOLD OUT</span>
                        }
                        else
                        {
                            <span class="fw-bold fs-5" style="color: #1db954;">$@beat.Price</span>
                        }
                    </div>

                    <form asp-action="Delete" method="post" onsubmit="return confirm('Вы уверены, что хотите удалить этот бит навсегда? Вернуть файлы будет невозможно.');">
                        <input type="hidden" name="id" value="@beat.Id" />
                        <button type="submit" class="delete-btn">
                            <i class="bi bi-trash3"></i> Удалить
                        </button>
                    </form>

                </div>
            }
        </div>
    }
</div>