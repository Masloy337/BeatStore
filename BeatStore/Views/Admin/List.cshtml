@model List<BeatStore.Models.Beat>

@{
    ViewData["Title"] = "Управление битами";
}

<style>
    /* Базовый контейнер */
    .admin-list-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    /* Поиск */
    .admin-search-wrapper {
        background: #141414;
        border: 1px solid #222;
        border-radius: 12px;
        padding: 10px 20px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .admin-search-input {
        background: transparent;
        border: none;
        color: #fff;
        flex: 1;
        outline: none;
        font-size: 15px;
    }

    /* Строка бита */
    .admin-row {
        background: #141414;
        border: 1px solid #222;
        border-radius: 16px;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 12px;
        transition: all 0.2s ease;
    }

        .admin-row:hover {
            border-color: #333;
            background: #1a1a1a;
        }

    /* Обложка */
    .image-wrapper {
        position: relative;
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .admin-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.2s;
    }

    .image-wrapper:hover .image-overlay {
        opacity: 1;
    }

    .overlay-play {
        background: #1db954;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: none;
        color: #000;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 12px;
    }

    /* Бейджи */
    .stat-group {
        display: flex;
        gap: 10px;
        min-width: 180px;
    }

    .admin-badge {
        background: #0a0a0a;
        border: 1px solid #222;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 12px;
        color: #888;
    }

    /* Кнопки действий */
    .action-group {
        display: flex;
        gap: 10px;
        margin-left: auto;
    }

    .btn-edit {
        background: transparent;
        color: #aaa;
        border: 1px solid #333;
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 13px;
        text-decoration: none;
        transition: 0.2s;
    }

        .btn-edit:hover {
            background: #333;
            color: #fff;
        }

    .delete-btn {
        background: rgba(255, 71, 87, 0.1);
        color: #ff4757;
        border: 1px solid transparent;
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        .delete-btn:hover {
            background: #ff4757;
            color: #fff;
        }
</style>

<div class="admin-list-container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white m-0">⚙️ Управление каталогом</h2>
        <a href="/Admin/Create" class="btn fw-bold px-4 rounded-pill" style="background: #1db954; color: #000;">
            + Добавить новый бит
        </a>
    </div>

    <div class="admin-search-wrapper">
        <span style="font-size: 18px;">🔍</span>
        <input type="text" id="adminSearch" class="admin-search-input" placeholder="Быстрый поиск по названию или жанру..." onkeyup="filterBeats()">
        <span class="text-secondary small">Всего: @Model.Count</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center p-5 shadow-lg" style="background: #141414; border-radius: 16px; border: 1px dashed #333;">
            <h1 style="font-size: 50px; margin-bottom: 15px;">🎛️</h1>
            <h4 class="text-white fw-bold">Каталог пуст</h4>
            <a href="/Admin/Create" class="btn btn-outline-light rounded-pill mt-3">Загрузить первый трек</a>
        </div>
    }
    else
    {
        <div id="beatsList">
            @foreach (var beat in Model)
            {
                var producer = string.IsNullOrEmpty(beat.ProducerName) ? "unknown" : beat.ProducerName;
                var cover = beat.CoverImagePath ?? "/images/no-image.png";
                var fileName = System.IO.Path.GetFileName(beat.DemoAudioPath);
                var demoSrc = "/File/Demo?fileName=" + fileName;

                <div class="admin-row" data-search="@beat.Title.ToLower() @beat.Genre?.ToLower()">

                    <div class="image-wrapper">
                        <img src="@cover" class="admin-cover" alt="cover" />
                        <div class="image-overlay">
                            <button class="overlay-play play-btn"
                                    data-id="@beat.Id" data-audio="@demoSrc"
                                    data-title="@beat.Title" data-cover="@cover"
                                    data-producer="@producer">
                                <span class="icon">▶</span>
                            </button>
                        </div>
                    </div>

                    <div style="flex: 2;">
                        <h6 class="fw-bold text-white mb-0">@beat.Title</h6>
                        <div class="text-secondary" style="font-size: 12px;">
                            @beat.Genre • @beat.Bpm BPM • <span class="text-info">@beat.CreatedAt.ToString("dd.MM.yyyy")</span>
                        </div>
                    </div>

                    <div class="stat-group d-none d-md-flex">
                        <div class="admin-badge">📈 @beat.PlayCount просл.</div>
                        <div class="admin-badge">❤️ @(beat.Likes?.Count ?? 0) лайков</div>
                    </div>

                    <div class="text-center" style="min-width: 80px;">
                        @if (beat.IsSold)
                        {
                            <span class="badge bg-danger" style="font-size: 10px;">SOLD</span>
                        }
                        else
                        {
                            <span class="fw-bold" style="color: #1db954;">$@beat.Price</span>
                        }
                    </div>

                    <div class="action-group">
                        <a href="/Admin/Edit/@beat.Id" class="btn-edit">Изменить</a>

                        <form asp-action="Delete" method="post" onsubmit="return confirm('Удалить бит навсегда?');" style="display:inline;">
                            <input type="hidden" name="id" value="@beat.Id" />
                            <button type="submit" class="delete-btn">Удалить</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    // 🔥 ФУНКЦИЯ ЖИВОГО ПОИСКА
    function filterBeats() {
        let input = document.getElementById('adminSearch').value.toLowerCase();
        let rows = document.querySelectorAll('.admin-row');

        rows.forEach(row => {
            let searchText = row.getAttribute('data-search');
            if (searchText.includes(input)) {
                row.style.display = 'flex';
            } else {
                row.style.display = 'none';
            }
        });
    }

    // Логика кнопок Play (Turbo-friendly)
    document.addEventListener('click', function(e) {
        const btn = e.target.closest('.play-btn');
        if (btn) {
            e.preventDefault();
            const src = btn.getAttribute('data-audio');
            const title = btn.getAttribute('data-title');
            const producer = btn.getAttribute('data-producer');
            const cover = btn.getAttribute('data-cover');

            if (typeof window.playGlobalTrack === 'function') {
                window.playGlobalTrack(src, title, producer, cover);
            }
        }
    });
</script>