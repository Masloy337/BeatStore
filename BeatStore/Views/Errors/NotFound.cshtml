@{
    Layout = "_Layout";
    ViewData["Title"] = "Упс! Бит не найден";
}

<div class="text-center" style="padding: 100px 20px;">
    <h1 style="font-size: 120px; font-weight: 800; color: #1db954; margin-bottom: 0;">404</h1>
    <h2 class="text-white fw-bold mb-4">Тишина в студии...</h2>
    <p class="text-secondary mb-5" style="max-width: 500px; margin: 0 auto 40px;">
        Похоже, этот трек был удален или ссылка ведет в никуда.
        Не переживай, в нашем каталоге еще сотни пушечных битов!
    </p>

    <a href="/Beats" class="btn fw-bold px-5 py-3 rounded-pill"
       style="background: #1db954; color: #000; font-size: 18px; transition: transform 0.2s;">
        🎧 Вернуться в каталог
    </a>
</div>
