@model BeatStore.Models.Beat

@{
    ViewData["Title"] = $"{Model.Title} | prod. {Model.ProducerName}";

    // Генерируем абсолютные ссылки для SEO
    var request = ViewContext.HttpContext.Request;
    var absoluteUrl = $"{request.Scheme}://{request.Host}{request.Path}";
    var absoluteImageUrl = $"{request.Scheme}://{request.Host}{(Model.CoverImagePath ?? "/images/no-image.png")}";
    var description = $"🔥 BPM: {Model.Bpm} | Жанр: {Model.Genre} | Слушай и покупай лицензию на новый бит от {Model.ProducerName}";
}

@section MetaTags {
    <meta property="og:type" content="music.song">
    <meta property="og:title" content="@Model.Title (@Model.Bpm BPM) — @Model.ProducerName">
    <meta property="og:description" content="@description">
    <meta property="og:image" content="@absoluteImageUrl">
    <meta property="og:url" content="@absoluteUrl">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@Model.Title | prod. @Model.ProducerName">
    <meta name="twitter:image" content="@absoluteImageUrl">

    <script type="application/ld+json">
        {
          "@@context": "https://schema.org/",
          "@@type": "Product",
          "name": "@Model.Title",
          "image": "@absoluteImageUrl",
          "description": "@description",
          "brand": {
            "@@type": "Brand",
            "name": "BeatStore"
          },
          "offers": {
            "@@type": "Offer",
            "url": "@absoluteUrl",
            "priceCurrency": "USD",
            "price": "@Model.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)",
            "availability": "@(Model.IsSold ? "https://schema.org/OutOfStock" : "https://schema.org/InStock")",
            "itemCondition": "https://schema.org/NewCondition"
          }
        }
    </script>
}

<style>
    .details-container {
        max-width: 1000px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .beat-hero {
        display: flex;
        gap: 40px;
        background: #141414;
        padding: 30px;
        border-radius: 24px;
        border: 1px solid #222;
        align-items: center;
        flex-wrap: wrap;
    }

    .hero-cover {
        width: 350px;
        height: 350px;
        border-radius: 16px;
        object-fit: cover;
        box-shadow: 0 20px 40px rgba(0,0,0,0.6);
    }

    .hero-info {
        flex: 1;
        min-width: 300px;
    }

        .hero-info h1 {
            font-size: 48px;
            font-weight: 900;
            margin-bottom: 5px;
            color: #fff;
        }

        .hero-info .producer-name {
            font-size: 20px;
            color: #1db954;
            font-weight: 600;
            margin-bottom: 25px;
            display: block;
            text-decoration: none;
        }

    .stats-row {
        display: flex;
        gap: 30px;
        margin-bottom: 30px;
        border-top: 1px solid #222;
        border-bottom: 1px solid #222;
        padding: 15px 0;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
    }

    .stat-label {
        color: #666;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .stat-value {
        color: #fff;
        font-size: 20px;
        font-weight: bold;
    }

    .action-btns {
        display: flex;
        gap: 15px;
    }

    .btn-play-big {
        background: #1db954;
        color: #000;
        border: none;
        padding: 15px 40px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .btn-play-big:hover {
            transform: scale(1.05);
            background: #1ed760;
        }

    .btn-cart-big {
        background: transparent;
        color: #fff;
        border: 2px solid #fff;
        padding: 15px 35px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-cart-big:hover {
            background: #fff;
            color: #000;
        }

    .tag-pill {
        background: #222;
        color: #aaa;
        padding: 5px 15px;
        border-radius: 20px;
        text-decoration: none;
        font-size: 13px;
        transition: 0.2s;
    }

        .tag-pill:hover {
            background: #333;
            color: #fff;
        }

    .tags-section {
        margin-top: 20px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }
</style>

<div class="details-container">
    <div class="beat-hero">
        <img src="@(Model.CoverImagePath ?? "/images/no-image.png")" class="hero-cover shadow" alt="@Model.Title" />

        <div class="hero-info">
            <h1>@Model.Title</h1>
            <span class="producer-name">@@@Model.ProducerName</span>

            <div class="stats-row">
                <div class="stat-item">
                    <span class="stat-label">BPM</span>
                    <span class="stat-value">@Model.Bpm</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Genre</span>
                    <span class="stat-value">@Model.Genre</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Plays</span>
                    <span class="stat-value">@Model.PlayCount</span>
                </div>
            </div>

            <div class="action-btns">
                @{
                    var fileName = System.IO.Path.GetFileName(Model.DemoAudioPath);
                    var demoSrc = "/File/Demo?fileName=" + fileName;
                }
                <button class="btn-play-big" onclick="window.playGlobalTrack('@demoSrc', '@Model.Title', '@Model.ProducerName', '@Model.CoverImagePath')">
                    ▶ Слушать
                </button>

                @if (!Model.IsSold)
                {
                    <button class="btn-cart-big" onclick="openModal(@Model.Id)">
                        🛒 Купить $@Model.Price
                    </button>
                }
                else
                {
                    <button class="btn-cart-big" disabled style="border-color: #444; color: #666;">SOLD OUT</button>
                }
            </div>

            <div class="tags-section">
                @if (!string.IsNullOrEmpty(Model.Tags))
                {
                    foreach (var tag in Model.Tags.Split(','))
                    {
                        <a href="/Beats?searchString=@tag.Trim()" class="tag-pill">#@tag.Trim().ToLower()</a>
                    }
                }
            </div>
        </div>
    </div>
</div>