@model List<BeatStore.Models.Order>

@{
    ViewData["Title"] = "Мои биты";
}

<style>
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 20px;
    }

    .card {
        background: #12121a;
        border-radius: 16px;
        padding: 15px;
        border: 1px solid #1db954;
    }

    /* 🔥 IMAGE + OVERLAY */
    .image-wrapper {
        position: relative;
        overflow: hidden;
        border-radius: 12px;
    }

        .image-wrapper img {
            width: 100%;
            height: 160px;
            object-fit: cover;
        }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.2s;
    }

    .image-wrapper:hover .image-overlay {
        opacity: 1;
    }

    /* 🔥 PLAY BUTTON */
    .overlay-play {
        background: #1db954;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: none;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        box-shadow: 0 0 20px rgba(29,185,84,0.6);
    }

    /* 🔥 EQ */
    .eq {
        display: flex;
        gap: 3px;
        align-items: flex-end;
        height: 20px;
    }

        .eq span {
            width: 3px;
            height: 6px;
            background: white;
            animation: eqAnim 1s infinite ease-in-out;
        }

            .eq span:nth-child(2) {
                animation-delay: 0.2s;
            }

            .eq span:nth-child(3) {
                animation-delay: 0.4s;
            }

    @@keyframes eqAnim {
        0% {
            height: 5px;
        }

        50% {
            height: 18px;
        }

        100% {
            height: 5px;
        }
    }

    .title {
        font-weight: bold;
        margin-top: 10px;
    }

    .meta {
        font-size: 12px;
        color: #aaa;
    }

    .license {
        margin-top: 10px;
        background: #0f0f15;
        padding: 8px;
        border-radius: 8px;
    }

    .download {
        margin-top: 12px;
        width: 100%;
    }
</style>

<h2>🎧 Мои биты</h2>

@if (!Model.Any())
{
    <p>У вас пока нет покупок</p>
}
else
{
    <div class="grid">

        @foreach (var order in Model)
        {
            var beat = order.Beat;
            var license = order.License;

            var fileName = System.IO.Path.GetFileName(beat?.DemoAudioPath);
            var demoSrc = "/File/Demo?fileName=" + fileName;

            <div class="card">

                <!-- 🔥 ОБЛОЖКА + PLAY -->
                <div class="image-wrapper">

                    <img src="@(beat?.CoverImagePath ?? "/images/no-image.png")" />

                    <div class="image-overlay">
                        <button class="overlay-play play-btn"
                                data-id="@beat?.Id"
                                data-audio="@demoSrc"
                                data-title="@beat?.Title">

                            <span class="icon">▶</span>

                            <div class="eq" style="display:none;">
                                <span></span><span></span><span></span>
                            </div>

                        </button>
                    </div>

                </div>

                <div class="title">@beat?.Title</div>

                <div class="meta">
                    @beat?.Genre • @beat?.Bpm BPM
                </div>

                <!-- 🔥 ЛИЦЕНЗИЯ -->
                <div class="license">

                    @if (license != null)
                    {
                        if (license.Name == "Basic")
                        {
                            <div>💿 MP3 Лицензия</div>
                        }
                        else if (license.Name == "Premium")
                        {
                            <div>🔥 WAV Лицензия</div>
                        }
                        else
                        {
                            <div>👑 Exclusive</div>
                        }

                        <div class="meta">
                            Куплено: @order.CreatedAt.ToString("dd.MM.yyyy")
                        </div>
                    }

                </div>

                <!-- 🔥 СКАЧАТЬ -->
                <a href="/File/Full?beatId=@beat?.Id">
                    <button class="download">
                        ⬇ Скачать
                    </button>
                </a>

            </div>
        }

    </div>
}