@using Microsoft.AspNetCore.Http
@using System.Text.Json
@{
    int cartCount = 0;
    var cartSession = Context.Session.GetString("cart");
    if (!string.IsNullOrEmpty(cartSession))
    {
        try
        {
            using var doc = JsonDocument.Parse(cartSession);
            cartCount = doc.RootElement.GetArrayLength();
        }
        catch { }
    }
}
<!DOCTYPE html>
<html lang="ru" data-bs-theme="dark" style="background-color: #0a0a0a;">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#0a0a0a" />
    <title>BeatStore - Premium Beats</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <script src="https://cdn.jsdelivr.net/npm/@@hotwired/turbo@8.0.4/dist/turbo.es2017-umd.js"></script>

    @RenderSection("MetaTags", required: false)
    <style>
        /* 1. ФИКС БЕЛОГО ФОНА */
        html {
            background-color: #0a0a0a !important;
        }

        body {
            background-color: #0a0a0a !important; /* Строго темный фон */
            color: #f0f0f0 !important; /* Строго светлый текст */
            font-family: 'Inter', 'Segoe UI', sans-serif;
            margin: 0;
            padding-bottom: 110px;
            overscroll-behavior-y: none;
        }

        /* =========================================
                   🔥 МОБИЛЬНАЯ АДАПТАЦИЯ (ИСПРАВЛЕННАЯ) 🔥
                   ========================================= */
        @@media (max-width: 768px) {
            /* --- 1. ШАПКА --- */
            .nav {
                display: flex !important;
                flex-direction: row !important;
                flex-wrap: nowrap !important;
                overflow-x: auto !important;
                align-items: center !important;
                gap: 15px !important;
                padding: 10px 15px !important;
                -webkit-overflow-scrolling: touch;
            }

                .nav > div, .nav > form, .nav > a {
                    display: flex !important;
                    flex-direction: row !important;
                    align-items: center !important;
                    gap: 15px !important;
                    white-space: nowrap !important;
                    flex-shrink: 0 !important;
                }

                .nav span.user-name {
                    display: none !important;
                }

                .nav::-webkit-scrollbar {
                    display: none;
                }
            /* --- 2. ПЛЕЕР --- */
            .global-player {
                padding: 10px 15px !important;
                padding-bottom: calc(10px + env(safe-area-inset-bottom)) !important;
                gap: 10px !important;
                height: auto !important;
                min-height: 80px;
            }
            /* Левый блок забирает оставшееся место, но не выталкивает кнопки */
            .gp-left {
                width: auto !important;
                flex: 1 !important;
                min-width: 0 !important; /* Обязательно для обрезки текста */
                gap: 10px !important;
            }

                .gp-left img {
                    width: 45px !important;
                    height: 45px !important;
                    min-width: 45px !important;
                }

            .gp-info {
                min-width: 0 !important;
            }

            .gp-title {
                font-size: 14px !important;
                white-space: nowrap !important;
                overflow: hidden !important;
                text-overflow: ellipsis !important; /* Добавляет "..." если не влезает */
            }
            /* Кнопки плеера берут только нужную ширину */
            .gp-controls {
                flex: none !important;
                width: auto !important;
                gap: 12px !important;
            }
            /* Правый блок (Корзина + Крестик) */
            .gp-right {
                flex: none !important;
                width: auto !important;
                gap: 10px !important;
            }
            /* 🔥 Прячем всё второстепенное на мобилках */
            .gp-time-display,
            .gp-volume-container,
            .gp-repeat-btn,
            button[title="Поделиться"] {
                display: none !important;
            }
            /* Делаем корзину чуть компактнее */
            .gp-cart-btn {
                padding: 6px 12px !important;
            }
        }

        /* --- БАЗОВЫЕ СТИЛИ (ДЕСКТОП) --- */
        .nav {
            background: rgba(18, 18, 26, 0.8);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-left a {
            color: #a0a0a0;
            margin-right: 25px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: color 0.3s ease;
        }

            .nav-left a:hover {
                color: #1db954;
            }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-name {
            color: #fff;
            font-weight: 600;
        }

        button.action-btn, .nav-right a.btn-login {
            background: #1db954;
            border: none;
            padding: 8px 18px;
            border-radius: 20px;
            color: #000;
            font-weight: bold;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s, background 0.2s;
        }

            button.action-btn:hover, .nav-right a.btn-login:hover {
                background: #1ed760;
                transform: scale(1.05);
            }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* --- СТИЛИ ТОСТЕРА --- */
        .premium-toast {
            background: rgba(20, 20, 20, 0.95);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-left: 4px solid #1db954;
            color: #fff;
            padding: 15px 20px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            min-width: 250px;
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55), opacity 0.4s;
            opacity: 0;
            display: flex;
            align-items: center;
            gap: 15px;
        }

            .premium-toast.show {
                transform: translateX(0);
                opacity: 1;
            }

        .toast-icon {
            font-size: 24px;
        }

        .toast-title {
            font-weight: 700;
            font-size: 15px;
            margin-bottom: 2px;
        }

        .toast-body {
            font-size: 13px;
            color: #aaa;
        }

        /* --- ПЛЕЕР --- */
        .global-player {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 85px;
            background: #141414;
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            box-shadow: 0 -5px 20px rgba(0,0,0,0.8);
            transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
            gap: 30px;
        }

            .global-player.show {
                transform: translateY(0) !important;
            }

        .gp-progress-container {
            position: absolute;
            top: -4px;
            left: 0;
            width: 100%;
            height: 4px;
            background: #2a2a2a;
            cursor: pointer;
        }

        .gp-progress-fill {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            background: #1db954;
            width: 0%;
            z-index: 1;
            pointer-events: none;
            transition: background 0.2s;
        }

        .gp-progress-container:hover .gp-progress-fill {
            background: #1ed760;
        }

        .gp-progress-bar {
            width: 100%;
            -webkit-appearance: none;
            height: 100%;
            background: transparent;
            outline: none;
            margin: 0;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 2;
        }

            .gp-progress-bar::-webkit-slider-thumb {
                -webkit-appearance: none;
                width: 12px;
                height: 12px;
                background: #fff;
                border-radius: 50%;
                cursor: pointer;
                opacity: 0;
                transition: transform 0.2s, opacity 0.2s;
            }

        .gp-progress-container:hover .gp-progress-bar::-webkit-slider-thumb {
            opacity: 1;
        }

        .gp-progress-bar:hover::-webkit-slider-thumb {
            transform: scale(1.3);
            background: #1db954;
        }

        .gp-left {
            display: flex;
            align-items: center;
            gap: 15px;
            width: 35%;
            min-width: 250px;
        }

            .gp-left img {
                width: 60px;
                height: 60px;
                border-radius: 6px;
                object-fit: cover;
            }

        .gp-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
            overflow: hidden;
            gap: 4px;
        }

        .gp-title-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .gp-title {
            color: #fff;
            font-weight: 700;
            font-size: 15px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .gp-producer {
            color: #888;
            font-size: 13px;
            font-weight: 500;
        }

        .gp-controls {
            display: flex;
            align-items: center;
            gap: 24px;
            flex: 1;
            justify-content: center;
        }

        .gp-icon-btn {
            background: none;
            border: none;
            color: #888;
            cursor: pointer;
            transition: color 0.2s, transform 0.2s;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .gp-icon-btn:hover {
                color: #fff;
                transform: scale(1.1);
            }

            .gp-icon-btn svg {
                width: 18px;
                height: 18px;
                fill: currentColor;
            }

        .gp-repeat-btn.active {
            color: #1db954;
        }

            .gp-repeat-btn.active:hover {
                color: #1ed760;
            }

        .gp-play-icon {
            background: none;
            border: none;
            color: #fff;
            cursor: pointer;
            transition: transform 0.2s, color 0.2s;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
        }

            .gp-play-icon:hover {
                transform: scale(1.1);
                color: #1db954;
            }

            .gp-play-icon svg {
                width: 28px;
                height: 28px;
                fill: currentColor;
            }

        .gp-time-display {
            display: flex;
            align-items: center;
            gap: 5px;
            color: #888;
            font-size: 13px;
            font-weight: 500;
            font-variant-numeric: tabular-nums;
            min-width: 80px;
            justify-content: center;
        }

        .gp-volume-container {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 110px;
            margin-left: 10px;
            color: #888;
        }

            .gp-volume-container svg {
                width: 18px;
                height: 18px;
                fill: currentColor;
            }

        .gp-volume-slider {
            width: 100%;
            -webkit-appearance: none;
            height: 4px;
            background: #444;
            border-radius: 2px;
            outline: none;
            cursor: pointer;
        }

            .gp-volume-slider::-webkit-slider-thumb {
                -webkit-appearance: none;
                width: 10px;
                height: 10px;
                background: #fff;
                border-radius: 50%;
                cursor: pointer;
            }

            .gp-volume-slider:hover::-webkit-slider-thumb {
                background: #1db954;
            }

        .gp-right {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 20px;
            width: 35%;
        }

        .gp-cart-btn {
            background: transparent;
            border: 1px solid #1db954;
            color: #1db954;
            font-size: 13px;
            font-weight: bold;
            padding: 6px 18px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .gp-cart-btn svg {
                width: 18px;
                height: 18px;
                fill: currentColor;
            }

            .gp-cart-btn:hover {
                background: #1db954;
                color: #000;
            }
    </style>
</head>
<body>

    <div class="nav">
        <div class="nav-left">
            <a href="/">Главная</a>
            <a href="/Beats">Биты</a>
            <a class="nav-link text-white d-flex align-items-center gap-1" href="/Cart">
                🛒 Корзина
                <span id="cart-counter" class="badge rounded-pill"
                      style="background-color: #ff4757; color: white; display: @(cartCount > 0 ? "inline-block" : "none"); font-size: 11px; padding: 4px 7px; transition: transform 0.2s;">
                    @cartCount
                </span>
            </a>

            @if (User.Identity.IsAuthenticated)
            {
                <a href="/Profile/Favorites">❤️ Избранное</a>
                <a href="/Profile/MyBeats">🎧 Мои биты</a>
            }

            @if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Create" style="color: #ff4757;">⚡ Загрузить</a>
                <a href="/Admin/List">Админка</a>
                <a href="/Admin/Stats">Статистика</a>
            }
        </div>

        <div class="nav-right">
            @if (User.Identity.IsAuthenticated)
            {
                <span class="user-name">@User.Identity.Name</span>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="display:inline;" data-turbo="false">
                    <button type="submit" class="action-btn" style="background: transparent; color: #fff; border: 1px solid #444;">Выйти</button>
                </form>
            }
            else
            {
                <a href="/Identity/Account/Login" class="nav-left" style="color: #fff; text-decoration: none; margin-right: 15px;">Вход</a>
               
            }
        </div>
    </div>

    <div class="container">
        @RenderBody()
    </div>

    <div id="turbo-permanent-wrapper" data-turbo-permanent="true">
        <div id="global-player" class="global-player" style="transform: translateY(150%);">
            <audio id="global-audio-element" src=""></audio>

            <div class="gp-progress-container">
                <div id="gp-progress-fill" class="gp-progress-fill"></div>
                <input type="range" id="gp-progress" class="gp-progress-bar" value="0" min="0" max="100" step="0.1" />
            </div>

            <div class="gp-left">
                <img id="gp-cover" src="/images/no-image.png" alt="Cover" />
                <div class="gp-info">
                    <div class="gp-title-row">
                        <div id="gp-title" class="gp-title">Название трека</div>
                    </div>
                    <div id="gp-producer" class="gp-producer">Продюсер</div>
                </div>
            </div>

            <div class="gp-controls">
                <button id="gp-repeat-btn" class="gp-icon-btn gp-repeat-btn" title="Повтор" onclick="window.toggleRepeat()">
                    <svg viewBox="0 0 24 24"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z" /></svg>
                </button>

                <button class="gp-icon-btn" title="Назад" onclick="window.prevTrack()">
                    <svg viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z" /></svg>
                </button>

                <button id="gp-play-btn" class="gp-play-icon">
                    <svg id="icon-play" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                </button>

                <button class="gp-icon-btn" title="Вперед" onclick="window.nextTrack()">
                    <svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z" /></svg>
                </button>

                <div class="gp-time-display">
                    <span id="gp-current-time">0:00</span>
                    <span style="color: #444; margin: 0 4px;">/</span>
                    <span id="gp-duration">0:00</span>
                </div>

                <div class="gp-volume-container">
                    <svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z" /></svg>
                    <input type="range" id="gp-volume" class="gp-volume-slider" min="0" max="1" step="0.01" value="0.5" />
                </div>
            </div>

            <div class="gp-right">
                <button class="gp-icon-btn" title="Поделиться" onclick="window.shareTrack()">
                    <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z" /></svg>
                </button>

                <button class="gp-cart-btn" onclick="window.openPlayerCart()">
                    <svg viewBox="0 0 24 24"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" /></svg>
                    <span id="gp-price">$0</span>
                </button>

                <button id="gp-close-btn" class="gp-icon-btn" title="Закрыть плеер">
                    <svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" /></svg>
                </button>
            </div>
        </div>

        <div id="toast-container" style="position: fixed; bottom: 100px; right: 20px; z-index: 1060; display: flex; flex-direction: column; gap: 10px;"></div>

        <script>
            window.audioPlayer = window.audioPlayer || document.getElementById('global-audio-element');
            window.playerQueue = window.playerQueue || [];
            window.currentIndex = window.currentIndex !== undefined ? window.currentIndex : -1;
            window.currentPlayingId = window.currentPlayingId || null;

            window.svgPlay = '<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
            window.svgPause = '<svg viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';

            window.showToast = function(title, message, icon = '🛒') {
                let container = document.getElementById('toast-container');
                if (!container) return;
                let toast = document.createElement('div');
                toast.className = 'premium-toast';
                toast.innerHTML = `<div class="toast-icon">${icon}</div><div><div class="toast-title">${title}</div><div class="toast-body">${message}</div></div>`;
                container.appendChild(toast);
                setTimeout(() => toast.classList.add('show'), 10);
                setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 400); }, 3000);
            };

            window.buildQueue = function() {
                window.playerQueue = [];
                document.querySelectorAll('.play-btn').forEach(btn => {
                    let card = btn.closest('.beat-card') || btn.closest('.beat-row') || btn.closest('.library-row');
                    let tagsHtml = ''; let priceText = '$0';

                    if (card) {
                        let tagsContainer = card.querySelector('.tags-container');
                        if (tagsContainer) tagsHtml = tagsContainer.innerHTML;
                        let priceBtn = card.querySelector('.price-btn');
                        if (priceBtn && !priceBtn.classList.contains('sold')) priceText = priceBtn.innerText;
                    }

                    window.playerQueue.push({
                        id: btn.getAttribute('data-id'), src: btn.getAttribute('data-audio'),
                        title: btn.getAttribute('data-title'), producer: btn.getAttribute('data-producer'),
                        cover: btn.getAttribute('data-cover'), tags: tagsHtml, price: priceText, btn: btn
                    });
                });
            };

            window.formatTime = function(seconds) {
                if (isNaN(seconds)) return "0:00";
                const m = Math.floor(seconds / 60); const s = Math.floor(seconds % 60);
                return `${m}:${s < 10 ? '0' : ''}${s}`;
            };

            window.playGlobalTrack = function(src, title, producer, cover) {
                window.buildQueue();
                const index = window.playerQueue.findIndex(t => t.src === src);
                if (index !== -1) window.playTrack(index);
            };

            window.playTrack = function(index) {
                if (index < 0 || index >= window.playerQueue.length) return;
                const track = window.playerQueue[index];

                if (window.currentIndex === index && window.audioPlayer.src.includes(track.src)) {
                    if (window.audioPlayer.paused) window.audioPlayer.play(); else window.audioPlayer.pause();
                    return;
                }

                window.currentIndex = index;
                window.audioPlayer.src = track.src;
                window.currentPlayingId = track.id;
                window.audioPlayer.play();

                document.getElementById('gp-title').innerText = track.title;
                document.getElementById('gp-producer').innerText = track.producer;
                document.getElementById('gp-cover').src = track.cover;

                document.getElementById('gp-price').innerText = track.price;

                document.getElementById('global-player').classList.add('show');
                document.querySelectorAll('.play-btn').forEach(btn => btn.innerHTML = '▶');
                if (track.btn) track.btn.innerHTML = '⏸';
            };

            window.nextTrack = function() { if (window.currentIndex + 1 < window.playerQueue.length) window.playTrack(window.currentIndex + 1); };
            window.prevTrack = function() { if (window.currentIndex - 1 >= 0) window.playTrack(window.currentIndex - 1); };

            window.openPlayerCart = function() {
                if (typeof openModal === 'function' && window.currentPlayingId) openModal(window.currentPlayingId);
                else window.showToast('Внимание', 'Этот трек уже куплен или не продается', '⚠️');
            };

            window.shareTrack = function() {
                if (!window.audioPlayer.src) return;
                const url = window.location.origin + "/Beats?searchString=" + encodeURIComponent(document.getElementById('gp-title').innerText);
                navigator.clipboard.writeText(url).then(() => window.showToast('Скопировано', 'Ссылка на трек скопирована в буфер', '🔗'));
            };

            window.toggleRepeat = function() {
                window.audioPlayer.loop = !window.audioPlayer.loop;
                const repeatBtn = document.getElementById('gp-repeat-btn');
                if (window.audioPlayer.loop) {
                    repeatBtn.classList.add('active');
                    window.showToast('Повтор', 'Включен повтор трека', '🔁');
                } else {
                    repeatBtn.classList.remove('active');
                }
            };

            if (!window.playerEventsAttached) {
                window.playerEventsAttached = true;

                const volumeSlider = document.getElementById('gp-volume');
                if (volumeSlider) {
                    window.audioPlayer.volume = volumeSlider.value;
                    volumeSlider.addEventListener('input', (e) => window.audioPlayer.volume = e.target.value);
                }

                document.getElementById('gp-play-btn').onclick = () => {
                    if (window.audioPlayer.paused) window.audioPlayer.play(); else window.audioPlayer.pause();
                };

                document.getElementById('gp-close-btn').onclick = () => {
                    window.audioPlayer.pause();
                    document.getElementById('global-player').classList.remove('show');
                    document.querySelectorAll('.play-btn').forEach(btn => btn.innerHTML = '▶');
                };

                window.audioPlayer.addEventListener('play', () => {
                    document.getElementById('gp-play-btn').innerHTML = window.svgPause;
                    if (window.currentIndex !== -1 && window.playerQueue[window.currentIndex]) {
                        if (window.playerQueue[window.currentIndex].btn) window.playerQueue[window.currentIndex].btn.innerHTML = '⏸';
                    }
                });

                window.audioPlayer.addEventListener('pause', () => {
                    document.getElementById('gp-play-btn').innerHTML = window.svgPlay;
                    if (window.currentIndex !== -1 && window.playerQueue[window.currentIndex]) {
                        if (window.playerQueue[window.currentIndex].btn) window.playerQueue[window.currentIndex].btn.innerHTML = '▶';
                    }
                });

                window.audioPlayer.addEventListener('ended', window.nextTrack);

                window.audioPlayer.addEventListener('timeupdate', () => {
                    document.getElementById('gp-current-time').innerText = window.formatTime(window.audioPlayer.currentTime);
                    if (window.audioPlayer.duration) {
                        const percent = (window.audioPlayer.currentTime / window.audioPlayer.duration) * 100;
                        document.getElementById('gp-progress').value = percent;
                        document.getElementById('gp-progress-fill').style.width = percent + '%';
                    }
                });

                window.audioPlayer.addEventListener('loadedmetadata', () => {
                    document.getElementById('gp-duration').innerText = window.formatTime(window.audioPlayer.duration);
                });

                document.getElementById('gp-progress').addEventListener('input', (e) => {
                    window.audioPlayer.currentTime = (e.target.value / 100) * window.audioPlayer.duration;
                });
            }

            window.toggleFavorite = function(beatId, btnElement) {
                fetch(`/Profile/ToggleFavorite?beatId=${beatId}`, { method: 'POST' })
                .then(response => {
                    if (response.status === 401 || response.status === 404) {
                        window.showToast('Внимание', 'Пожалуйста, войдите в аккаунт, чтобы сохранять биты', '🔒');
                        return null;
                    }
                    return response.json();
                })
                .then(data => {
                    if (data && data.success) {
                        if (data.isLiked) {
                            btnElement.innerHTML = '❤️';
                            btnElement.classList.add('liked');
                            window.showToast('Избранное', 'Бит добавлен в вашу коллекцию', '❤️');
                        } else {
                            btnElement.innerHTML = '🤍';
                            btnElement.classList.remove('liked');
                            window.showToast('Избранное', 'Бит удален из коллекции', '🤍');
                        }
                    }
                })
                .catch(err => console.error('Ошибка лайка:', err));
            }
        </script>
    </div>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>